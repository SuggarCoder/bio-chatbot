{
    "compilerOptions": {
      "target": "ES2022",
      "useDefineForClassFields": true,
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "lib": [
        "ES2022",
        "DOM",
        "DOM.Iterable"
      ],
      "jsx": "preserve",
      "jsxImportSource": "solid-js",
      "strict": true,
      "noEmit": true,
      "resolveJsonModule": true,
      "isolatedModules": true,
      "skipLibCheck": true,
      "types": [
        "vite/client"
      ]
    },
    "include": [
      "src/client",
      "vite.config.ts",
      "uno.config.ts"
    ]
  }