{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "rootDir": "src/server",
      "outDir": "dist/server",
      "strict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "types": [
        "node"
      ]
    },
    "include": [
      "src/server/**/*.ts"
    ]
  }